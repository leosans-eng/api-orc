# Copie para .env na raiz deste repositório:
#   copy .env.example .env
#
# === SERVIDOR (produção) ===
# Use run_dev.bat (Docker Desktop). O Compose sobe API + Postgres e
# monta DATABASE_URL para o host interno "db" automaticamente.
# Obrigatório alterar antes de liberar aos clientes:
SECRET_KEY=troque-esta-chave-em-producao
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password

# Senha do Postgres (Compose). Em produção, troque orc_dev.
POSTGRES_USER=orc
POSTGRES_PASSWORD=orc_dev
POSTGRES_DB=orc
POSTGRES_PORT=5432
API_PORT=8000

# === SÓ DESENVOLVIMENTO LOCAL (run_local.bat) ===
# No servidor essas linhas NÃO afetam o host do banco no Compose
# (ele força @db:5432). No PC de dev, use localhost para o Postgres no WSL:
DATABASE_URL=postgresql+psycopg2://orc:orc_dev@localhost:5432/orc
SEED_DATA_DIR=dados_usuario
API_HOST=0.0.0.0
